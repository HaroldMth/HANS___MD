# HANS MD ENVIRONMENT VARIABLES - EXAMPLE
# Rename this file to .env and fill in your details

# --- Session & Authentication ---
# Your MEGA-based Session ID (Must start with HANS-BYTE~)
SESSION_ID=HANS-BYTE~PASTE_YOUR_ID_HERE
PAIRING_SERVER_URL=https://session.hanstech.xyz

# --- Bot Identity ---
BOT_NAME=HANS MD
OWNER_NAME=Harold
OWNER_NUMBER=237680260772
PREFIX=.

# --- Automation Settings (true/false) ---
AUTO_REACT=true
ANTI_DELETE=true
AUTO_READ=true
AUTO_STATUS=true
AUTO_TYPING=true
AUTO_RECORDING=true
ALWAYS_ONLINE=true

# --- External Integration ---
GITHUB_URL=https://github.com/haroldmth/hans__md
REPO_NAME=hans__md

# --- Notifications & Reporting ---
# Telegram Bot Token for error reporting (Optional)
TG_BOT_TOKEN=
TG_CHAT_ID=
